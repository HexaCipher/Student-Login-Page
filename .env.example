# Environment Variables Template
# 
# NOTE: For this vanilla JS project, environment variables are used during
# Vercel deployment. For local development, edit config.js directly.
#
# VERCEL DEPLOYMENT:
# Set these in Vercel Dashboard → Settings → Environment Variables
# The build script (build-config.js) will inject them into config.js

# Get these values from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=PASTE_YOUR_URL_HERE
SUPABASE_ANON_KEY=PASTE_YOUR_ANON_KEY_HERE
